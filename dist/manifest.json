{
  "manifest_version": 3,
  "name": "RearAware",
  "version": "0.1.0",
  "version_name": "0.1.0 Beta",
  "description": "Real time AI webcam filter that detects and censors cat butts during video calls.",
  "action": {
    "default_popup": "/src/popup/popup.html",
    "default_icon": {
      "16": "icons/ra16.png",
      "32": "icons/ra32.png"
    }
  },
  "icons": {
    "16": "icons/ra16.png",
    "32": "icons/ra32.png",
    "48": "icons/ra48.png",
    "128": "icons/ra128.png"
  },
  "permissions": [
    "storage",
    "activeTab",
    "tabs"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "content_scripts": [
    {
      "js": [
        "assets/content.js-loader-z6oIp9jO.js"
      ],
      "matches": [
        "https://meet.google.com/*",
        "https://teams.microsoft.com/*"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "matches": [
        "<all_urls>"
      ],
      "resources": [
        "assets/*",
        "models/*",
        "sounds/*"
      ],
      "use_dynamic_url": false
    },
    {
      "matches": [
        "https://meet.google.com/*",
        "https://teams.microsoft.com/*"
      ],
      "resources": [
        "assets/ort-wasm-simd-threaded.asyncify-CvvOzbbq.wasm",
        "assets/ort-wasm-simd-threaded-Cpm-ox6i.wasm",
        "assets/detector-5I9LkXWI.js",
        "assets/content.js-CXG8rfgv.js",
        "assets/ort.webgpu.bundle.min-DFaXX46o.js",
        "assets/ort.wasm.bundle.min-I9-ZZJ6I.js"
      ],
      "use_dynamic_url": false
    }
  ]
}
